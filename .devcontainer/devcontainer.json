{
  "name": "desafio-tecnico-full-stack",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.13-bookworm",
  "forwardPorts": [8010, 8089, 8090, 8000],
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    }
  },
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y php-cli && pip install -r backend/requirements.txt",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-azuretools.vscode-docker"
      ]
    }
  }
}