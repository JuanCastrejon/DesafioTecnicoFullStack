APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:8089,http://127.0.0.1:8089,http://localhost:8090,http://127.0.0.1:8090,http://localhost:3000
ENABLE_IN_MEMORY_FALLBACK=false
RUN_DB_BOOTSTRAP=false
SEED_EVENTS=false
SEED_EVENTS_TOTAL=10000
# Para entorno local con Docker DB (perfil local-db):
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/events_db

# Para Supabase pooler (produccion/staging), usar este formato y reemplazar valores:
# DATABASE_URL=postgresql+psycopg://postgres.<project-id>:<password>@aws-1-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require
